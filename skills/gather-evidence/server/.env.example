# Copy to .env and fill in. .env is gitignored — never commit real values.

# DNS name pointing at this VM. Needs a public A record for a real Let's Encrypt
# cert (camo rejects self-signed). No domain? Use the nip.io trick with your
# droplet's IP, e.g. EVIDENCE_DOMAIN=evidence.203-0-113-7.nip.io
EVIDENCE_DOMAIN=evidence.example.com

# Hardcoded write token. Generate one: openssl rand -hex 24
# Clients (the uploader) send it as: Authorization: Bearer <this>
EVIDENCE_TOKEN=replace-me-with-a-long-random-string
