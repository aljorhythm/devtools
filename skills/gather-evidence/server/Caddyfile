# Caddy fronts dufs: auto-HTTPS + bearer-gated writes, public reads.
{$EVIDENCE_DOMAIN} {
	# Block any write that doesn't carry the exact bearer token. Reads (GET/HEAD)
	# fall through unauthenticated so GitHub's camo proxy can fetch and render the
	# image inline — the URL is public-but-unguessable, not enumerable.
	@unauthorized_write {
		method PUT POST DELETE MKCOL PATCH
		not header Authorization "Bearer {$EVIDENCE_TOKEN}"
	}
	respond @unauthorized_write 401

	reverse_proxy dufs:5000
}
